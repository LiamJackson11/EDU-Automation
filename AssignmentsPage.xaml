<?xml version="1.0" encoding="utf-8" ?>
<!-- Views/AssignmentsPage.xaml -->

<ContentPage
    x:Class="EduAutomation.Views.AssignmentsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:EduAutomation.ViewModels"
    Title="Missing Assignments">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16" RowSpacing="12">

        <!-- Status bar -->
        <Label Grid.Row="0" Text="{Binding StatusMessage}"
               FontSize="13" TextColor="Gray" />

        <!-- Load button -->
        <Button Grid.Row="1"
                Text="Refresh Missing Assignments"
                Command="{Binding LoadMissingAssignmentsCommand}"
                IsEnabled="{Binding IsNotBusy}"
                BackgroundColor="#3f51b5" TextColor="White"
                CornerRadius="8" HeightRequest="44" />

        <!-- Assignment List -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding MissingAssignments}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedAssignment}"
                        EmptyView="No missing assignments found. Tap Refresh to check.">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 10" Padding="14" Margin="0,5"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e2e}">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4">
                            <Label Grid.Row="0" Text="{Binding Title}"
                                   FontSize="15" FontAttributes="Bold" />
                            <Label Grid.Row="1" Text="{Binding CourseName}"
                                   FontSize="13" TextColor="Gray" />
                            <Label Grid.Row="2" Text="{Binding DueDateDisplay}"
                                   FontSize="12" TextColor="#e65100" />
                            <HorizontalStackLayout Grid.Row="3" Spacing="8">
                                <Label Text="{Binding Source}"
                                       FontSize="10" TextColor="White"
                                       BackgroundColor="#607d8b" Padding="5,2" />
                                <Label Text="MISSING" FontSize="10" TextColor="White"
                                       BackgroundColor="#f44336" Padding="5,2"
                                       IsVisible="{Binding IsOverdue}" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Generate AI Content button (appears when an assignment is selected) -->
        <Grid Grid.Row="3" RowDefinitions="Auto,Auto" RowSpacing="8">
            <Button Grid.Row="0"
                    Text="Generate AI Content for Selected Assignment"
                    Command="{Binding GenerateAiContentCommand}"
                    CommandParameter="{Binding SelectedAssignment}"
                    IsEnabled="{Binding IsNotBusy}"
                    IsVisible="{Binding SelectedAssignment, Converter={StaticResource NotNullConverter}}"
                    BackgroundColor="#4caf50" TextColor="White"
                    CornerRadius="8" HeightRequest="48" />

            <ActivityIndicator Grid.Row="1"
                               IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="#3f51b5" />

            <Border Grid.Row="1" IsVisible="{Binding HasError}"
                    BackgroundColor="#ffebee" StrokeShape="RoundRectangle 8" Padding="10">
                <Label Text="{Binding ErrorMessage}" TextColor="#c62828" FontSize="13" />
            </Border>
        </Grid>

    </Grid>
</ContentPage>
